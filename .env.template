# === Application ===
APP_ENV=development
APP_VERSION=1.0.0
LOG_LEVEL=info

# === API Authentication ===
CMS_API_KEY=change-me-to-a-secret
REVIEW_JWT_SECRET=change-me

# === Database ===
DATABASE_URL=postgresql://user:pass@localhost:5432/evropuvefur

# === DeepInfra Embeddings ===
DEEPINFRA_API_KEY=
DEEPINFRA_MODEL=intfloat/multilingual-e5-large

# === Google Gemini ===
GEMINI_API_KEY=
GEMINI_PRO_MODEL=gemini-3-pro-preview
GEMINI_FLASH_MODEL=gemini-3-flash-preview
GEMINI_PRO_DAILY_LIMIT=200

# === CORS ===
CORS_ALLOWED_ORIGINS=https://www.evropuvefur.is,https://evropuvefur.is

# === Rate Limiting ===
QUERY_RATE_LIMIT=10/minute
SYNC_RATE_LIMIT=100/minute

# === Cache ===
QUERY_CACHE_TTL_HOURS=24

# === RAG ===
RAG_TOP_K=5
RAG_SCORE_THRESHOLD=0.3
